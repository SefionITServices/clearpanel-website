# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret — from Stripe Dashboard > Webhooks
# or from: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs — create products in Stripe Dashboard and paste the price IDs here
# Product: "clearPanel Starter" — $3.99/month
STRIPE_PRICE_STARTER_MONTHLY="price_..."
# Product: "clearPanel Starter" — $39/year
STRIPE_PRICE_STARTER_YEARLY="price_..."

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Random secret for JWT signing — generate with: openssl rand -hex 32
JWT_SECRET="your-random-secret-hex-here"
